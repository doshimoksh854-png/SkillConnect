<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@color/md_theme_light_background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Welcome Header with gradient -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_gradient_primary"
            android:padding="@dimen/spacing_lg"
            android:paddingBottom="@dimen/spacing_xl">

            <TextView
                android:id="@+id/tvGreeting"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Hello! 👋"
                android:textColor="@color/white_70"
                android:textSize="@dimen/text_size_body"
                android:fontFamily="sans-serif" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_xs"
                android:text="@string/welcome_back"
                android:textColor="@color/white"
                android:textSize="@dimen/text_size_headline_medium"
                android:fontFamily="sans-serif-black" />

            <!-- Search Bar -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/searchCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_lg"
                app:cardCornerRadius="28dp"
                app:cardElevation="4dp"
                android:clickable="true"
                android:focusable="true">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="@dimen/spacing_lg"
                    android:paddingEnd="@dimen/spacing_base">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_nav_search"
                        android:layout_marginEnd="@dimen/spacing_md"
                        android:contentDescription="@string/cd_search"
                        app:tint="@color/md_theme_light_onSurfaceVariant" />

                    <EditText
                        android:id="@+id/etSearch"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:hint="@string/search_skills"
                        android:textColor="@color/md_theme_light_onSurface"
                        android:textColorHint="@color/md_theme_light_onSurfaceVariant"
                        android:textSize="@dimen/text_size_caption"
                        android:background="@android:color/transparent"
                        android:inputType="text"
                        android:imeOptions="actionSearch"
                        android:maxLines="1" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>

        <!-- Content area -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/spacing_base">

            <!-- My Jobs Banner -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardMyJobs"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:clickable="true"
                android:focusable="true"
                app:cardBackgroundColor="?attr/colorPrimaryContainer"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="20dp"
                    android:gravity="center_vertical">
                    
                    <ImageView
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:src="@drawable/ic_jobs"
                        app:tint="?attr/colorOnPrimaryContainer" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="16dp"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="My Posted Jobs"
                            android:textSize="18sp"
                            android:fontFamily="sans-serif-medium"
                            android:textColor="?attr/colorOnPrimaryContainer" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Manage your requests and view proposals"
                            android:textSize="13sp"
                            android:textColor="?attr/colorOnPrimaryContainer"
                            android:alpha="0.8" />
                    </LinearLayout>
                    
                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_nav_home" 
                        android:rotation="270"
                        app:tint="?attr/colorOnPrimaryContainer"/>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- My Wallet Banner -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardMyWallet"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:clickable="true"
                android:focusable="true"
                app:cardBackgroundColor="?attr/colorSecondaryContainer"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="20dp"
                    android:gravity="center_vertical">
                    
                    <ImageView
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:src="@drawable/ic_nav_bookings"
                        app:tint="?attr/colorOnSecondaryContainer" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="16dp"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="My Wallet"
                            android:textSize="18sp"
                            android:fontFamily="sans-serif-medium"
                            android:textColor="?attr/colorOnSecondaryContainer" />

                        <TextView
                            android:id="@+id/tvCustomerWalletBalance"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Manage your funds"
                            android:textSize="13sp"
                            android:textColor="?attr/colorOnSecondaryContainer"
                            android:alpha="0.8" />
                    </LinearLayout>
                    
                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_nav_home" 
                        android:rotation="270"
                        app:tint="?attr/colorOnSecondaryContainer"/>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Categories Section -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_sm"
                android:text="@string/browse_categories"
                android:textColor="@color/md_theme_light_onBackground"
                android:textSize="@dimen/text_size_headline_small"
                android:fontFamily="sans-serif-medium" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvCategories"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_md"
                android:nestedScrollingEnabled="false" />

            <!-- Featured Providers Section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_lg"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/featured_providers"
                    android:textColor="@color/md_theme_light_onBackground"
                    android:textSize="@dimen/text_size_headline_small"
                    android:fontFamily="sans-serif-medium" />

                <com.google.android.material.button.MaterialButton
                    style="@style/Widget.SkillConnect.Button.Text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/view_all"
                    android:textColor="@color/md_theme_light_primary"
                    android:minHeight="40dp" />

            </LinearLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvFeaturedProviders"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_md"
                android:nestedScrollingEnabled="false"
                android:orientation="horizontal"
                android:clipToPadding="false"
                android:paddingBottom="@dimen/spacing_base" />

        </LinearLayout>

    </LinearLayout>

</androidx.core.widget.NestedScrollView>
